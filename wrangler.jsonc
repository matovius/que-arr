{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "que-arr",
	"compatibility_date": "2026-04-24",
	"compatibility_flags": ["nodejs_als"],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"routes": [
		{
			"custom_domain": true,
			"pattern": "qr.matovius.dev"
		}
	]
}
